# ============================================================
# Sistema Noé — grow-guard-system
# .env.example — copie para .env e preencha os valores
# ============================================================
#
# Este arquivo documenta as variáveis de ambiente esperadas.
# - Variáveis VITE_* são públicas (vão pro bundle frontend)
# - Variáveis sem prefixo são consumidas em edge functions
#   (configuradas no Lovable Secrets, não em .env local)
#
# NUNCA commitar o .env real.

# ─────────────────────────────────────────────
# FRONTEND (Vite — público, vai no bundle)
# ─────────────────────────────────────────────
VITE_SUPABASE_PROJECT_ID=gxrhdpbbxfipeopdyygn
VITE_SUPABASE_URL=https://gxrhdpbbxfipeopdyygn.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key-do-supabase-dashboard>

# ─────────────────────────────────────────────
# EDGE FUNCTIONS — Supabase (auto-injected pelo runtime)
# ─────────────────────────────────────────────
# Não precisa setar localmente. Documentado pra referência.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# ASAAS (gateway de pagamento — produção)
# ─────────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_PROXY_URL=
ASAAS_WEBHOOK_TOKEN=

# ─────────────────────────────────────────────
# META / FACEBOOK (Ads + Leadgen + WhatsApp Cloud)
# ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_CLIENT_ID=
META_CLIENT_SECRET=
META_LEADGEN_VERIFY_TOKEN=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# EVOLUTION API (WhatsApp via VPS Lamadre)
# ─────────────────────────────────────────────
EVOLUTION_API_URL=https://evo.grupolamadre.com.br
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# GOOGLE (Ads + OAuth)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ─────────────────────────────────────────────
# LINKEDIN (Ads + OAuth)
# ─────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─────────────────────────────────────────────
# LOVABLE AI GATEWAY
# ─────────────────────────────────────────────
LOVABLE_API_KEY=
LOVABLE_SEND_URL=

# ─────────────────────────────────────────────
# IZITECH CROSS (integração SMTP server VPS Lamadre)
# ─────────────────────────────────────────────
IZITECH_CROSS_API_KEY=

# ─────────────────────────────────────────────
# WEBHOOKS internos
# ─────────────────────────────────────────────
CRM_WEBHOOK_SECRET=
CRM_LEAD_WEBHOOK_SECRET=
CANDIDATE_WEBHOOK_TOKEN=

# ─────────────────────────────────────────────
# CRON / Sistema
# ─────────────────────────────────────────────
CRON_SECRET=
OAUTH_STATE_SECRET=
FRONTEND_URL=https://app.noexcuse.com.br
SITE_URL=https://noexcuse.com.br

# ─────────────────────────────────────────────
# RESEND (email transacional)
# ─────────────────────────────────────────────
RESEND_API_KEY=
